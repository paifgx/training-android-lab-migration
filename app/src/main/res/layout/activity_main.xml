<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/brand_navy"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:id="@+id/mainTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="DepotFlow"
        android:textColor="@color/brand_light"
        android:textSize="34sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Legacy Java baseline for migration training"
        android:textColor="@color/brand_light"
        android:textSize="16sp" />

    <TextView
        android:id="@+id/mainSummary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:background="@drawable/card_background"
        android:padding="16dp"
        android:textColor="@color/text_primary"
        android:textSize="15sp" />

    <Button
        android:id="@+id/openOrdersButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:background="@drawable/button_primary"
        android:text="Work Orders öffnen"
        android:textColor="@android:color/white" />

    <Button
        android:id="@+id/openSyncButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:background="@drawable/button_primary"
        android:text="Outbox / Sync öffnen"
        android:textColor="@android:color/white" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="Hinweis: Diese App ist absichtlich legacy. Nicht als Zielarchitektur verwenden."
        android:textColor="@color/brand_accent"
        android:textSize="14sp" />
</LinearLayout>
